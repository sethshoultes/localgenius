0:["b4754d9jBKwZBP-KoKbfu",[[["",{"children":["(marketing)",{"children":["about",{"children":["__PAGE__",{}]}]}]},"$undefined","$undefined",true],["",{"children":["(marketing)",{"children":["about",{"children":["__PAGE__",{},[["$L1",[["$","section",null,{"className":"px-screen-margin pt-16 pb-12 max-w-[720px] mx-auto","children":[["$","h1",null,{"className":"text-[2rem] leading-[1.15] font-semibold text-charcoal tracking-tight sm:text-[2.5rem]","children":"We started with one question."}],["$","p",null,{"className":"text-[1.25rem] text-terracotta font-semibold mt-4 sm:text-[1.5rem]","children":"What if every local business had a marketing employee?"}]]}],["$","section",null,{"className":"px-screen-margin py-12 max-w-[720px] mx-auto","children":[["$","h2",null,{"className":"text-h1 text-charcoal mb-6","children":"The Problem"}],["$","div",null,{"className":"flex flex-col gap-4 text-body text-slate leading-relaxed","children":[["$","p",null,{"children":"Maria owns a Tex-Mex restaurant in Austin. She's been open for seven years. She manages a kitchen, a team, vendors, health inspections — all with competence and grit. But marketing? Marketing makes her feel like she's drowning in a language she doesn't speak."}],["$","p",null,{"children":"She's tried hiring her nephew to post on Instagram. She's tried Mailchimp. She's paid an agency $1,200 a month for generic posts that didn't sound like her restaurant. Nothing stuck. Every tool assumed she was a marketer. She's not. She's a chef."}],["$","p",null,{"children":"There are 33 million Marias in America. Sixty percent of them have an inadequate digital presence. Not because they don't care — because every tool they've tried was built for someone else."}]]}]]}],["$","section",null,{"className":"px-screen-margin py-12 bg-cream","children":["$","div",null,{"className":"max-w-[720px] mx-auto","children":[["$","h2",null,{"className":"text-h1 text-charcoal mb-6","children":"What we built"}],["$","div",null,{"className":"flex flex-col gap-4 text-body text-slate leading-relaxed","children":[["$","p",null,{"children":"LocalGenius is the employee Maria always needed but could never afford. One conversation. Everything handled."}],["$","p",null,{"children":"She talks to it the way she'd talk to a person: “Post something about our lunch special.” “Respond to that bad review.” “How did we do this month?” It handles her website, her reviews, her social posts, her email campaigns, her Google listing, and a weekly report that takes 90 seconds to read."}],["$","p",null,{"children":"She doesn't learn a new tool. She doesn't configure anything. She doesn't choose fonts or templates. She talks, and it does the rest. An agency charges $1,500 a month. A part-time social media person costs $500. LocalGenius costs $29."}],["$","p",null,{"className":"text-charcoal font-semibold","children":"Five minutes to set up. Three minutes a day to run. And every Monday, a 90-second report that proves it's working."}]]}]]}]}],["$","section",null,{"className":"px-screen-margin py-12 max-w-[720px] mx-auto","children":[["$","h2",null,{"className":"text-h1 text-charcoal mb-6","children":"The Team"}],["$","div",null,{"className":"flex flex-col gap-4 text-body text-slate leading-relaxed","children":[["$","p",null,{"children":"We're a small team in Austin, Texas. Six people who believe that local businesses deserve the same marketing power that big companies take for granted — without the complexity, the jargon, or the $1,500 monthly invoice."}],["$","p",null,{"children":"Half of us have built consumer products used by millions. The other half have sat across from small business owners and felt the weight of how hard it is to run a business and do marketing at the same time."}],["$","p",null,{"children":"We eat at Austin restaurants every Friday. Not just for lunch — to notice the owner behind the counter, the Google listing on the door, the Instagram handle on the receipt. That's who we build for. We know them."}]]}],["$","div