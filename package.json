{
  "name": "localgenius",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered digital presence platform for local businesses",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/db/seeds/index.ts",
    "db:studio": "drizzle-kit studio",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "load-test": "tsx scripts/load-test.ts",
    "smoke-test": "tsx scripts/smoke-test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@neondatabase/serverless": "^0.10.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.57.2",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.2",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-metrics": "^1.30.1",
    "@opentelemetry/sdk-node": "^0.57.2",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@opentelemetry/sdk-trace-node": "^1.30.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "autoprefixer": "^10.4.27",
    "drizzle-orm": "^0.36.0",
    "jose": "^5.9.0",
    "next": "^14.2.0",
    "postcss": "^8.5.8",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "resend": "^4.1.0",
    "stripe": "^21.0.1",
    "tailwindcss": "^4.2.2",
    "twilio": "^5.13.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/addon-onboarding": "^10.3.4",
    "@storybook/addon-vitest": "^10.3.4",
    "@storybook/nextjs-vite": "^10.3.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/browser": "^2.1.9",
    "@vitest/coverage-v8": "^2.1.9",
    "dotenv": "^17.4.0",
    "drizzle-kit": "^0.28.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "eslint-plugin-storybook": "^10.3.4",
    "jsdom": "^25.0.1",
    "playwright": "^1.59.1",
    "storybook": "^10.3.4",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vite": "^8.0.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "eslintConfig": {
    "extends": [
      "next/core-web-vitals"
    ],
    "rules": {
      "react/no-unescaped-entities": "off"
    },
    "ignorePatterns": [
      "src/__tests__/**",
      "e2e/**",
      "scripts/**",
      "src/stories/**",
      "*.config.js",
      "*.config.ts"
    ]
  }
}
