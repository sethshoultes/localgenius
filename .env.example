# ─── Database (Neon Serverless PostgreSQL) ─────────────────────────────────────
DATABASE_URL=postgresql://user:password@hostname/dbname?sslmode=require

# ─── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=generate-a-secure-random-string-at-least-32-chars

# ─── AI Provider (Anthropic Claude) ────────────────────────────────────────────
# Sonnet 4.6 for interactive, Haiku 4.5 for batch (see tech-stack.md)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ─── Image Generation (Replicate / Flux) ──────────────────────────────────────
REPLICATE_API_TOKEN=r8_xxxxx

# ─── Google Business Profile API ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx

# ─── Meta Graph API (Instagram + Facebook) ─────────────────────────────────────
META_APP_ID=xxxxx
META_APP_SECRET=xxxxx

# ─── Yelp Fusion API ──────────────────────────────────────────────────────────
YELP_API_KEY=xxxxx

# ─── Stripe (Payments) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ─── Redis (Upstash — job queue, caching, rate limiting) ──────────────────────
REDIS_URL=redis://default:xxxxx@hostname:6379

# ─── Email / SMS (Twilio SendGrid) ────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxx
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx

# ─── Object Storage (Cloudflare R2) ───────────────────────────────────────────
R2_ACCESS_KEY_ID=xxxxx
R2_SECRET_ACCESS_KEY=xxxxx
R2_BUCKET_NAME=localgenius-media
R2_ENDPOINT=https://xxxxx.r2.cloudflarestorage.com

# ─── Encryption (Platform OAuth tokens at rest) ───────────────────────────────
ENCRYPTION_KEY=generate-a-32-byte-hex-key

# ─── Monitoring (Sentry) ──────────────────────────────────────────────────────
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ─── Application ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
